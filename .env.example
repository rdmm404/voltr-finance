# API server
VOLTR_API_ADDRESS=:8080
VOLTR_API_KEY=replace-with-a-long-random-secret

# PostgreSQL
DB_USER=voltr
DB_PASSWORD=replace-with-database-password
DB_NAME=voltr_finance
DB_HOST=db
DB_PORT=5432
DB_POOL_SIZE=5
DB_MIN_POOL_SIZE=0

# Standalone CLI (the CLI config file may provide these instead)
VOLTR_API_URL=http://localhost:8080
# VOLTR_API_KEY is shared with the server in local development.
